# WebPulse Assessment Backend Environment Variables

# App
APP_ENV=development
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-2024-08-06

# ClickUp CRM
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# Calendly
CALENDLY_API_TOKEN=
CALENDLY_EVENT_TYPE_URI=
CALENDLY_WEBHOOK_SIGNING_KEY=

# Resend Email
RESEND_API_KEY=
EMAIL_FROM=WebPulse <reports@webpulsehq.com>

# Security
JWT_SECRET=change-me-in-production
RECAPTCHA_SECRET=
